# ==============================
# SimCity environment template
# ==============================
# Copy to .env and edit values.
#
# Notes:
# - For ENS mint/push/sync commands, MNEMONIC + RPC_URL required.
# - For local sim only (no ENS writes), MNEMONIC/RPC_URL optional.

# ---------- Storage ----------
# Optional custom data dir (default: ~/.citysim)
CITYSIM_HOME=~/.citysim

# ---------- LLM routing ----------
# Provider options: ollama-openai | openai
CITYSIM_LLM_PROVIDER=ollama-openai

# Ollama model/tag in local ollama list (example: tinyllama)
CITYSIM_OLLAMA_MODEL=tinyllama
# Ollama OpenAI-compatible base URL
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional OpenAI settings (needed for audit tier if using openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional per-tier override (advanced)
# CITYSIM_LLM_PROVIDER_AGENT=ollama-openai
# CITYSIM_LLM_PROVIDER_AUDIT=openai

# ---------- ENS / wallet ----------
# Used by ENS mint/push/probe scripts and wallet derivation
MNEMONIC=
# Stable Sepolia RPC URL (Infura/Alchemy/etc)
RPC_URL=

# Optional explicit mnemonic var used by some citysim flows
CITYSIM_WALLET_MNEMONIC=

# ENS settings
CITYSIM_ENS_BASE_DOMAIN=simcity-7890.eth
ENS_REGISTRY_ADDRESS=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
ENS_PUBLIC_RESOLVER_ADDRESS=0x8FADE66B79cC9f707aB26799354482EB93a5B7dD

# ---------- Dialogue scheduler ----------
CITYSIM_AUTO_DIALOGUE=1
# Number of concurrent dialogue workers (can be changed at runtime from UI)
CITYSIM_DIALOGUE_WORKERS=1
# Real seconds between worker dialogue attempts
CITYSIM_DIALOGUE_PAUSE_S=5.0
# Max turns per dialogue
CITYSIM_DIALOGUE_MAX_TURNS=6
# Share of baseline generic dialogues in product mode
CITYSIM_BASELINE_RATIO=0.25

# ---------- Transport mode ----------
# local | axl
CITYSIM_TRANSPORT=axl
# 1 = fail dialogue when transport fails, 0 = fallback local
CITYSIM_TRANSPORT_REQUIRED=1

# ---------- AXL node orchestration ----------
# 1 = backend auto-spawns/kills node processes with app lifecycle
CITYSIM_AXL_AUTOSPAWN=1
# Desired active node count (can be changed at runtime from UI)
CITYSIM_AXL_NODE_COUNT=2

# Legacy fixed ports (used if dynamic ports not supplied)
CITYSIM_AXL_NODE_A_PORT=9002
CITYSIM_AXL_NODE_B_PORT=9012

# Advanced: dynamic lists (set by backend autospawn reconcile)
# CITYSIM_AXL_NODE_PORTS=9002,9012
# CITYSIM_AXL_NODE_PEER_IDS=<peer1>,<peer2>

# Legacy peer IDs (used when CSV not set)
CITYSIM_AXL_NODE_A_PEER_ID=1fd26e5f5247f758e5204b281247036daf95d768b615dccc57de5859078a15b3
CITYSIM_AXL_NODE_B_PEER_ID=63d1c9d07ab3b30c5aaf2c369ee00ae1b264c63194856401049570c1562798cc

# AXL send behavior
CITYSIM_AXL_TIMEOUT_S=10
CITYSIM_AXL_POLL_INTERVAL_S=0.2
CITYSIM_AXL_SEND_RETRIES=2
CITYSIM_AXL_BACKOFF_S=0.4
